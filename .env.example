# AxonHub admin credentials (required)
AXONHUB_URL=https://your-axonhub-instance.example.com
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=your-admin-password

# Server port (optional, default: 3001)
PORT=3001

# Production startup notes:
# 1) Run `npm run build:all`
# 2) Run `npm start`
# The Express server will automatically serve the frontend from ./dist when present.
